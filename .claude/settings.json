{
  "permissions": {
    "allow": [
      "Bash(git config *)",
      "Bash(git ls-remote *)",
      "mcp__aspire__list_apphosts",
      "mcp__aspire__doctor",
      "Bash(aspire --version)",
      "Bash(dotnet --version)",
      "Bash(aspire run *)"
    ],
    "deny": [
      "Read(./Hexalith.*/_bmad/**)",
      "Read(./Hexalith.*/_bmad-output/**)",
      "Read(./Hexalith.*/.claude/skills/bmad-*/**)",
      "Read(./Hexalith.*/.codex/**)",
      "Bash(git submodule update --init --recursive)",
      "Bash(git submodule update --recursive)",
      "Bash(git submodule update --init --remote --recursive)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "env PROJECT_ROOT=/home/administrator/projects/hexalith/projects /home/administrator/projects/hexalith/projects/.claude/skills/bmad-story-automator/scripts/story-automator stop-hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
