{
  "name": "hexalith-projects-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-module Playwright E2E workspace for the Hexalith.Projects platform (Aspire AppHost: eventstore + tenants + projects + workers + projects-ui + Keycloak). Mirrors Hexalith.FrontComposer/tests/e2e conventions.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:smoke": "playwright test specs/framework-smoke.spec.ts --project=chromium",
    "test:a11y": "playwright test specs/projects-accessibility.spec.ts --project=chromium",
    "install:browsers": "playwright install --with-deps",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.54.1",
    "@seontechnologies/playwright-utils": "^3.14.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
