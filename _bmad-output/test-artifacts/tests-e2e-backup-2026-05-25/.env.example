# Hexalith.Projects cross-module E2E — environment template.
# Copy to `.env` (gitignored) and fill in. CI injects these as secrets.

# --- Target environment ---
TEST_ENV=local
# projects-ui base URL (Blazor web). Defaults to the planned dev port in playwright.config.ts.
BASE_URL=https://localhost:7280
# Projects REST API (AR-15 OpenAPI spine). Often same host as BASE_URL or a sibling port.
API_URL=https://localhost:7280

# --- Local web server (greenfield guard) ---
# The Hexalith.Projects AppHost does not exist yet. Leave OFF until Story 1.1 lands.
# Set to 1 and provide E2E_WEBSERVER_CMD to have Playwright launch the AppHost.
E2E_WEBSERVER=0
# E2E_WEBSERVER_CMD=dotnet run --project ../../Hexalith.Projects/src/Hexalith.Projects.AppHost --no-launch-profile

# --- Real Keycloak / OIDC (AR-19; E2E uses real tokens, not synthetic JWTs) ---
KEYCLOAK_URL=https://localhost:8443
KEYCLOAK_REALM=hexalith
KEYCLOAK_CLIENT_ID=hexalith-projects-e2e
# Confidential client secret (omit for public clients).
# KEYCLOAK_CLIENT_SECRET=
# Default test user (resource-owner password grant). Per-user accounts override via authOptions.userIdentifier.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
# Tenant the default test user belongs to (drives {tenant}:projects:{projectId} isolation).
TEST_TENANT_ID=

# --- Optional auth pre-fetch in global setup (off by default so smoke runs offline) ---
E2E_AUTH_PREFETCH=0
