@page "/"
@page "/projects"
@page "/projects/warnings"
@using Hexalith.Projects.Contracts.Ui
@using Hexalith.Projects.UI.Diagnostics
@inject IProjectWarningsDashboardSource WarningsDashboard

<section class="project-inventory" aria-labelledby="project-inventory-heading">
    <header class="project-inventory__header">
        <div>
            <p class="project-inventory__scope" data-testid="project-inventory-tenant-scope">@TenantScope</p>
            <h1 id="project-inventory-heading">Projects</h1>
        </div>
        <div class="project-inventory__freshness" data-testid="project-inventory-freshness">
            @FreshnessSummary
        </div>
    </header>

    @if (!_loading && _result?.Feedback is null)
    {
        <section class="project-operational-dashboard"
                 data-testid="project-warnings-dashboard"
                 aria-labelledby="project-warnings-dashboard-heading">
            <h2 id="project-warnings-dashboard-heading">Operational dashboard</h2>
            <div class="project-operational-dashboard__tiles">
                @foreach (DashboardTile tile in DashboardTiles)
                {
                    <button type="button"
                            class="project-operational-dashboard__tile"
                            data-testid="project-dashboard-tile"
                            aria-label="@($"{tile.Label}: {tile.Value}")"
                            @onclick="() => ApplyDashboardFilterAsync(tile.Filter)">
                        <span>@tile.Value</span>
                        <strong>@tile.Label</strong>
                    </button>
                }
            </div>
        </section>
    }

    <form class="project-inventory__filters" aria-label="Project inventory filters">
        <label data-testid="project-warning-filter-lifecycle">
            <span>Lifecycle</span>
            <select data-testid="project-inventory-filter-lifecycle"
                    value="@_selectedLifecycle"
                    @onchange="OnLifecycleChangedAsync">
                <option value="">All</option>
                <option value="@ProjectLifecycle.Active">Active</option>
                <option value="@ProjectLifecycle.Archived">Archived</option>
            </select>
        </label>
        <label>
            <span>Updated</span>
            <select data-testid="project-inventory-filter-updated"
                    value="@_updatedWindow"
                    @onchange="OnUpdatedWindowChanged">
                <option value="all">Any time</option>
                <option value="24h">Last 24 hours</option>
                <option value="7d">Last 7 days</option>
                <option value="30d">Last 30 days</option>
            </select>
        </label>
        <label>
            <span>Warnings</span>
            <select data-testid="project-warning-filter-state"
                    value="@_selectedWarningState"
                    @onchange="OnWarningStateChanged">
                <option value="">All warning states</option>
                @foreach (ReferenceState state in WarningStates)
                {
                    <option value="@state">@ProjectVocabularyDescriptors.Describe(state).DisplayLabel</option>
                }
            </select>
        </label>
        <label>
            <span>Reason</span>
            <select data-testid="project-warning-filter-reason"
                    value="@_selectedReasonCode"
                    @onchange="OnReasonCodeChanged">
                <option value="">All reasons</option>
                @foreach (ProjectReasonCode reason in ReasonCodes)
                {
                    <option value="@reason">@ProjectVocabularyDescriptors.Describe(reason).DisplayLabel</option>
                }
            </select>
        </label>
        <label>
            <span>Reference</span>
            <select data-testid="project-warning-filter-reference-type"
                    value="@_selectedReferenceKind"
                    @onchange="OnReferenceKindChanged">
                <option value="">All references</option>
                @foreach (string referenceKind in ReferenceKinds)
                {
                    <option value="@referenceKind">@referenceKind</option>
                }
            </select>
        </label>
    </form>

    @if (_loading)
    {
        <ProjectFeedbackView Feedback="@ProjectConsoleFeedback.Loading("project_inventory_loading")" />
    }
    else if (_result?.Feedback is not null)
    {
        <ProjectFeedbackView Feedback="@_result.Feedback" />
    }
    else if (FilteredQueueItems.Count == 0 && (_result?.QueueItems.Count ?? 0) == 0)
    {
        <div data-testid="project-warning-empty">
            <ProjectEmptyStateView State="@ProjectEmptyState.NoWarnings()" ProjectionType="@typeof(ProjectWarningQueueItemProjection)" />
        </div>
    }
    else if (FilteredQueueItems.Count == 0)
    {
        <div data-testid="project-warning-empty">
            <ProjectEmptyStateView State="@ProjectEmptyState.FilterReturnedNoResults()" ProjectionType="@typeof(ProjectWarningQueueItemProjection)" />
        </div>
    }
    else
    {
        <section class="project-warnings-queue"
                 data-testid="project-warnings-queue"
                 aria-labelledby="project-warnings-queue-heading">
            <h2 id="project-warnings-queue-heading">Warnings queue</h2>
            <div class="project-inventory__table-wrap">
                <table class="project-inventory__table">
                    <caption>Project warnings queue</caption>
                    <thead>
                        <tr>
                            <th scope="col">Project</th>
                            <th scope="col">Lifecycle</th>
                            <th scope="col">State</th>
                            <th scope="col">Reason</th>
                            <th scope="col">Reference</th>
                            <th scope="col">Freshness</th>
                            <th scope="col">Safe action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ProjectWarningQueueItemProjection item in FilteredQueueItems)
                        {
                            <tr data-testid="project-warning-row" tabindex="0">
                                <th scope="row">
                                    <a href="@ProjectLink(item.ProjectId)"
                                       aria-label="@($"Open project {item.ProjectName}")">
                                        <span>@item.ProjectName</span>
                                        <code>@item.ProjectId</code>
                                    </a>
                                </th>
                                <td>
                                    <ProjectStatusBadge Descriptor="@ProjectVocabularyDescriptors.Describe(item.Lifecycle)" ColumnHeader="Lifecycle" />
                                </td>
                                <td data-testid="project-warning-state">
                                    <ProjectStatusBadge Descriptor="@ProjectVocabularyDescriptors.Describe(item.State)" ColumnHeader="Warning state" />
                                    <span class="project-warnings-queue__status-text">@ProjectVocabularyDescriptors.Describe(item.State).AccessibleName</span>
                                </td>
                                <td data-testid="project-warning-reason">@ReasonText(item.ReasonCode)</td>
                                <td data-testid="project-warning-reference">
                                    @if (string.IsNullOrWhiteSpace(item.ReferenceKind))
                                    {
                                        <span>project diagnostic</span>
                                    }
                                    else
                                    {
                                        <span>@item.ReferenceKind</span>
                                        <code>@item.ReferenceId</code>
                                        <small>@item.OwnerContext</small>
                                    }
                                </td>
                                <td data-testid="project-warning-freshness">
                                    <time datetime="@item.LastObservedAt.ToString("O", System.Globalization.CultureInfo.InvariantCulture)">
                                        @item.LastObservedAt.ToString("u", System.Globalization.CultureInfo.InvariantCulture)
                                    </time>
                                    <span>@item.FreshnessTrustState</span>
                                    @if (!string.IsNullOrWhiteSpace(item.ProjectionWatermark))
                                    {
                                        <code>@item.ProjectionWatermark</code>
                                    }
                                </td>
                                <td data-testid="project-warning-safe-action">
                                    <div class="project-warnings-queue__actions" aria-label="@($"Safe actions for {item.ProjectId}")">
                                        <a href="@ProjectLink(item.ProjectId)">Open project</a>
                                        <a href="@ProjectLink(item.ProjectId)">References</a>
                                        <a href="@ProjectLink(item.ProjectId)">Audit</a>
                                        <button type="button" aria-disabled="true">Handled by Story 5.9</button>
                                        <span>@item.SafeActionAvailabilityLabel</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }

    @if (!_loading && _result?.Feedback is null)
    {
        @if (FilteredRows.Count == 0 && (_result?.InventoryRows.Count ?? 0) == 0)
        {
            <div data-testid="project-inventory-empty">
                <ProjectEmptyStateView State="@ProjectEmptyState.NoProjects()" ProjectionType="@typeof(ProjectInventoryRowProjection)" />
            </div>
        }
        else if (FilteredRows.Count == 0)
        {
            <div data-testid="project-inventory-empty">
                <ProjectEmptyStateView State="@ProjectEmptyState.FilterReturnedNoResults()" ProjectionType="@typeof(ProjectInventoryRowProjection)" />
            </div>
        }
        else
        {
            <div class="project-inventory__table-wrap" data-testid="project-inventory-grid">
                <table class="project-inventory__table">
                    <caption>Project inventory</caption>
                    <thead>
                        <tr>
                            <th scope="col">Project</th>
                            <th scope="col">Lifecycle</th>
                            <th scope="col">Warnings</th>
                            <th scope="col">Updated</th>
                            <th scope="col">Freshness</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ProjectInventoryRowProjection row in FilteredRows)
                        {
                            <tr data-testid="project-inventory-row">
                                <th scope="row">
                                    <a href="@($"/projects/{Uri.EscapeDataString(row.ProjectId)}")"
                                       data-testid="project-inventory-row-link"
                                       aria-label="@($"Open project {row.Name}")">
                                        <span>@row.Name</span>
                                        <code>@row.ProjectId</code>
                                    </a>
                                </th>
                                <td>
                                    <ProjectStatusBadge Descriptor="@ProjectVocabularyDescriptors.Describe(row.Lifecycle)" ColumnHeader="Lifecycle" />
                                </td>
                                <td>
                                    <span data-testid="project-inventory-warning-summary">@row.WarningSummary</span>
                                </td>
                                <td>
                                    <time datetime="@row.UpdatedAt.ToString("O", System.Globalization.CultureInfo.InvariantCulture)">
                                        @row.UpdatedAt.ToString("u", System.Globalization.CultureInfo.InvariantCulture)
                                    </time>
                                </td>
                                <td>
                                    <span>@row.FreshnessTrustState</span>
                                    @if (!string.IsNullOrWhiteSpace(row.ProjectionWatermark))
                                    {
                                        <code>@row.ProjectionWatermark</code>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</section>

@code {
    private ProjectWarningsDashboardLoadResult? _result;
    private bool _loading = true;
    private string _selectedLifecycle = string.Empty;
    private string _updatedWindow = "all";
    private string _selectedWarningState = string.Empty;
    private IReadOnlyCollection<ReferenceState> _warningStateFilter = [];
    private string _selectedReasonCode = string.Empty;
    private string _selectedReferenceKind = string.Empty;

    private string TenantScope => _result?.TenantScope ?? "server-derived tenant";

    private string FreshnessSummary
        => FilteredRows.Count == 0
            ? "No rows"
            : string.Join(", ", FilteredRows.Select(r => r.FreshnessTrustState).Distinct(StringComparer.OrdinalIgnoreCase));

    private IReadOnlyList<ProjectInventoryRowProjection> FilteredRows
        => ApplyUpdatedFilter(_result?.InventoryRows ?? []);

    private IReadOnlyList<ProjectWarningQueueItemProjection> FilteredQueueItems
        => ApplyQueueFilters(_result?.QueueItems ?? []);

    private IReadOnlyList<ReferenceState> WarningStates
        => (_result?.QueueItems ?? [])
            .Select(item => item.State)
            .Distinct()
            .OrderBy(state => state.ToString(), StringComparer.Ordinal)
            .ToArray();

    private IReadOnlyList<ProjectReasonCode> ReasonCodes
        => (_result?.QueueItems ?? [])
            .Select(item => item.ReasonCode)
            .OfType<ProjectReasonCode>()
            .Distinct()
            .OrderBy(reason => reason.ToString(), StringComparer.Ordinal)
            .ToArray();

    private IReadOnlyList<string> ReferenceKinds
        => (_result?.QueueItems ?? [])
            .Select(item => item.ReferenceKind)
            .Where(kind => !string.IsNullOrWhiteSpace(kind))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(kind => kind, StringComparer.Ordinal)
            .ToArray();

    private IReadOnlyList<DashboardTile> DashboardTiles
        => _result is null
            ? []
            :
            [
                new("Total visible", _result.Dashboard.TotalVisibleProjects, DashboardFilter.All),
                new("Active", _result.Dashboard.ActiveProjects, DashboardFilter.Active),
                new("Archived", _result.Dashboard.ArchivedProjects, DashboardFilter.Archived),
                new("Warning projects", _result.Dashboard.ProjectsWithWarnings, DashboardFilter.Warnings),
                new("Stale", _result.Dashboard.StaleReferences, DashboardFilter.Stale),
                new("Conflicts", _result.Dashboard.Conflicts, DashboardFilter.Conflict),
                new("Invalid", _result.Dashboard.InvalidReferences, DashboardFilter.Invalid),
                new("Denied/unavailable", _result.Dashboard.UnauthorizedOrUnavailableReferences, DashboardFilter.Unavailable),
                new("Ambiguous/fail-closed", _result.Dashboard.AmbiguousOrFailClosed, DashboardFilter.Ambiguous),
                new("Diagnostic unavailable", _result.Dashboard.DiagnosticUnavailable, DashboardFilter.DiagnosticUnavailable),
            ];

    protected override async Task OnInitializedAsync()
        => await LoadAsync().ConfigureAwait(true);

    private async Task OnLifecycleChangedAsync(ChangeEventArgs args)
    {
        _selectedLifecycle = args.Value?.ToString() ?? string.Empty;
        await LoadAsync().ConfigureAwait(true);
    }

    private void OnUpdatedWindowChanged(ChangeEventArgs args)
        => _updatedWindow = args.Value?.ToString() ?? "all";

    private void OnWarningStateChanged(ChangeEventArgs args)
    {
        _selectedWarningState = args.Value?.ToString() ?? string.Empty;
        _warningStateFilter = Enum.TryParse(_selectedWarningState, ignoreCase: true, out ReferenceState state)
            ? [state]
            : [];
    }

    private void OnReasonCodeChanged(ChangeEventArgs args)
        => _selectedReasonCode = args.Value?.ToString() ?? string.Empty;

    private void OnReferenceKindChanged(ChangeEventArgs args)
        => _selectedReferenceKind = args.Value?.ToString() ?? string.Empty;

    private async Task LoadAsync()
    {
        _loading = true;
        _result = await WarningsDashboard
            .LoadAsync(ParseLifecycle(_selectedLifecycle), CancellationToken.None)
            .ConfigureAwait(true);
        _loading = false;
    }

    private IReadOnlyList<ProjectInventoryRowProjection> ApplyUpdatedFilter(IReadOnlyList<ProjectInventoryRowProjection> rows)
    {
        DateTimeOffset? since = _updatedWindow switch
        {
            "24h" => DateTimeOffset.UtcNow.AddHours(-24),
            "7d" => DateTimeOffset.UtcNow.AddDays(-7),
            "30d" => DateTimeOffset.UtcNow.AddDays(-30),
            _ => null,
        };

        return since is null
            ? rows
            : rows.Where(row => row.UpdatedAt >= since.Value).ToArray();
    }

    private IReadOnlyList<ProjectWarningQueueItemProjection> ApplyQueueFilters(IReadOnlyList<ProjectWarningQueueItemProjection> items)
    {
        IEnumerable<ProjectWarningQueueItemProjection> filtered = items;
        if (_warningStateFilter.Count > 0)
        {
            filtered = filtered.Where(item => _warningStateFilter.Contains(item.State));
        }

        if (Enum.TryParse(_selectedReasonCode, ignoreCase: true, out ProjectReasonCode reason))
        {
            filtered = filtered.Where(item => item.ReasonCode == reason);
        }

        if (!string.IsNullOrWhiteSpace(_selectedReferenceKind))
        {
            filtered = filtered.Where(item => string.Equals(
                item.ReferenceKind,
                _selectedReferenceKind,
                StringComparison.Ordinal));
        }

        return ApplyUpdatedFilter(filtered
            .Select(item => item)
            .ToArray());
    }

    private IReadOnlyList<ProjectWarningQueueItemProjection> ApplyUpdatedFilter(IReadOnlyList<ProjectWarningQueueItemProjection> rows)
    {
        DateTimeOffset? since = _updatedWindow switch
        {
            "24h" => DateTimeOffset.UtcNow.AddHours(-24),
            "7d" => DateTimeOffset.UtcNow.AddDays(-7),
            "30d" => DateTimeOffset.UtcNow.AddDays(-30),
            _ => null,
        };

        return since is null
            ? rows
            : rows.Where(row => row.LastObservedAt >= since.Value).ToArray();
    }

    private static ProjectLifecycle? ParseLifecycle(string? value)
        => Enum.TryParse(value, ignoreCase: true, out ProjectLifecycle lifecycle)
            ? lifecycle
            : null;

    private async Task ApplyDashboardFilterAsync(DashboardFilter filter)
    {
        // Lifecycle is a server-side query parameter, so lifecycle tiles must re-query rather than only
        // setting the dropdown value (which would leave the loaded rows unchanged).
        if (filter is DashboardFilter.Active or DashboardFilter.Archived)
        {
            _selectedLifecycle = filter == DashboardFilter.Active
                ? ProjectLifecycle.Active.ToString()
                : ProjectLifecycle.Archived.ToString();
            await LoadAsync().ConfigureAwait(true);
            return;
        }

        // Warning tiles drive a state-set filter so the queue shows exactly the states the tile counts
        // (grouped tiles must not silently hide part of their own count).
        _warningStateFilter = filter switch
        {
            DashboardFilter.Stale => [ReferenceState.Stale],
            DashboardFilter.Conflict => [ReferenceState.Conflict],
            DashboardFilter.Invalid => [ReferenceState.InvalidReference],
            DashboardFilter.Unavailable => [ReferenceState.Unauthorized, ReferenceState.Unavailable],
            DashboardFilter.Ambiguous => [ReferenceState.Ambiguous, ReferenceState.TenantMismatch],
            DashboardFilter.DiagnosticUnavailable => [ReferenceState.Unavailable],
            _ => [],
        };

        // The single-select dropdown can only reflect a single state; clear it for multi-state groups.
        _selectedWarningState = _warningStateFilter.Count == 1
            ? _warningStateFilter.First().ToString()
            : string.Empty;
    }

    private static string ProjectLink(string projectId)
        => $"/projects/{Uri.EscapeDataString(projectId)}";

    private static string ReasonText(ProjectReasonCode? reason)
        => reason is null
            ? "unavailable"
            : $"{ProjectVocabularyDescriptors.Describe(reason.Value).DisplayLabel} ({reason.Value})";

    private sealed record DashboardTile(string Label, int Value, DashboardFilter Filter);

    private enum DashboardFilter
    {
        All,
        Active,
        Archived,
        Warnings,
        Stale,
        Conflict,
        Invalid,
        Unavailable,
        Ambiguous,
        DiagnosticUnavailable,
    }
}
