# Hexalith.Projects live AppHost E2E environment template.
# Copy to `.env` (gitignored). Discover local URLs with `aspire describe`; do not guess ports.

# --- Target environment ---
TEST_ENV=local
# Leave 0 for no-AppHost selector/contracts. Set 1 only after exporting every discovered URL below.
E2E_LIVE_APPHOST=0
# `projects-ui` HTTP URL from `aspire describe`.
BASE_URL=
# `projects` HTTP URL from `aspire describe` (distinct from BASE_URL).
API_URL=

# --- Real Keycloak / OIDC (AR-19; E2E uses real tokens, not synthetic JWTs) ---
# `security` HTTP URL from `aspire describe` (local Aspire currently exposes HTTPS here).
KEYCLOAK_URL=
KEYCLOAK_REALM=hexalith
KEYCLOAK_CLIENT_ID=hexalith-eventstore
# Confidential client secret (omit for public clients).
# KEYCLOAK_CLIENT_SECRET=
# Default test user (resource-owner password grant). Per-user accounts override via authOptions.userIdentifier.
# Username from the local realm. TEST_USER_EMAIL remains accepted as a legacy alias.
TEST_USER_USERNAME=
TEST_USER_PASSWORD=
# Tenant the default test user belongs to (drives {tenant}:projects:{projectId} isolation).
TEST_TENANT_ID=

# --- Optional offline auth pre-fetch; live mode always pre-fetches a fresh token ---
E2E_AUTH_PREFETCH=0
